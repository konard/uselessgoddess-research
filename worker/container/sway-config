# Sway configuration for CS2 farming container
# Minimal headless Wayland compositor

# Use Alt as modifier (Mod1) — avoids conflict with host Super key
set $mod Mod1

# Headless output at CS2 resolution
output Virtual-1 {
    mode 384x288
    scale 1
}

# Disable all decorations
default_border none
default_floating_border none
titlebar_border_thickness 0
titlebar_padding 0

# Start wayvnc for remote display access
exec wayvnc --output=Virtual-1 0.0.0.0 5900

# No idle/swaylock (farming session runs indefinitely)
exec swaymsg inhibit_idle open
